# Helgrind Restrictive Generic Suppressions for cpp_dbc
# Generated: 2026-02-13 (Restrictive Version)
#
# This file uses RESTRICTIVE wildcard patterns to suppress ONLY Catch2 race conditions.
# Each suppression requires MULTIPLE Catch2-specific functions in the stack trace
# to ensure we don't accidentally suppress races from cpp_dbc code.
#
# Syntax:
#   ...       = Matches 0 or more stack frames
#   *         = Wildcard for any text
#   fun:*X*   = Any function containing X
#
# SAFETY: All suppressions require 2+ Catch2 functions to match
# Total patterns: 24 restrictive suppressions

# ============================================
# System/Library suppressions
# ============================================

{
   helgrind_misc_001
   Helgrind:Misc
   obj:/usr/libexec/valgrind/vgpreload_helgrind-amd64-linux.so
   obj:/usr/lib/x86_64-linux-gnu/libp11-kit.so.0.3.0
   fun:_dl_fini
   fun:__run_exit_handlers
   fun:exit
   fun:(below main)
}

# backward-cpp + libdw false positive
# This occurs during stack trace capture/resolution and cleanup when backward-cpp
# uses libdw. libdw uses pthread_rwlock_t internally for symbol resolution, but
# Helgrind cannot see the relationship between the rwlock initialization (inside
# libdw) and its destruction during cleanup.
#
# Stack traces (multiple variants):
# - Thread cleanup → dwfl_end → dwarf_end → tdestroy → rwlock_destroy
# - Symbol resolution → dwarf_begin_elf → dwfl_module_addrdie → rwlock operations
# - TraceResolver::~TraceResolver() → handle cleanup → dwfl_end
#
# SAFETY: This suppression is specific to:
# 1. Misc errors (not Race) from rwlock operations
# 2. Inside libdw.so (DWARF symbol library)
# 3. Only affects stack trace resolution, not cpp_dbc logic
#
# NOTE: Covers ALL libdw operations (cleanup, resolution, etc.) because the
# rwlock false positive can occur during any libdw operation under Helgrind
{
   backward_libdw_rwlock_all_operations
   Helgrind:Misc
   ...
   obj:*/libdw*.so
   ...
}

# OpenSSL libcrypto rwlock false positive
# This occurs when OpenSSL performs SSL/TLS operations (certificate decoding,
# key management, BIO cleanup, etc.). libcrypto uses pthread_rwlock_t internally
# for thread safety, but Helgrind cannot see the relationship between the rwlock
# initialization (inside libcrypto) and its destruction during cleanup.
#
# Stack traces (multiple variants):
# - CRYPTO_THREAD_lock_free → BIO_free → OSSL_DECODER_from_bio/data
# - CRYPTO_THREAD_lock_free → EC_KEY_free → EVP_PKEY_free → SSL_free
#
# SAFETY: This suppression is specific to:
# 1. Misc errors (not Race) from rwlock operations
# 2. Inside libcrypto.so (OpenSSL cryptography library)
# 3. Called from CRYPTO_THREAD_lock_free (OpenSSL thread cleanup)
# 4. Only affects SSL/crypto operations, not cpp_dbc logic
#
# NOTE: This is a known Helgrind false positive with OpenSSL 3.x
{
   libcrypto_rwlock_destroy_ssl_operations
   Helgrind:Misc
   ...
   fun:CRYPTO_THREAD_lock_free
   ...
}

