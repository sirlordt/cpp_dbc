# ============================================
# SAFETY ANALYSIS
# ============================================
#
# These 24 restrictive suppressions are SAFER than the previous version because:
#
# 1. Each suppression requires 2+ Catch2-specific functions in the stack
# 2. If a race occurs in cpp_dbc code, it will NOT have multiple Catch2 functions
# 3. Stack traces from cpp_dbc races would look like:
#    - cpp_dbc::MySQLConnection::someMethod
#    - cpp_dbc::ConnectionPool::getConnection
#    - [Maybe Catch2 at top if called from test]
#    But NOT multiple Catch2 functions throughout the stack
#
# 4. These patterns match ONLY when the race is deep inside Catch2 internals
#
# CONFIDENCE: Very high that cpp_dbc races will NOT be suppressed
#
# ============================================
# std::condition_variable_any False Positives
# ============================================
#
# Helgrind reports false positives for std::condition_variable_any because it
# cannot track the complex internal mutex protocol used by condition_variable_any.
#
# BACKGROUND:
# std::condition_variable_any internally creates its own std::mutex (separate from
# the user's mutex) to protect its internal state. When notify_one() is called:
#   1. It acquires this internal mutex
#   2. Signals waiting threads
#   3. Releases the internal mutex
#
# Helgrind sees the internal mutex being locked/unlocked by different threads
# (the notifying thread vs the waiting thread) and reports this as a violation.
#
# This is a WELL-KNOWN false positive documented in:
# - libstdc++ bug reports
# - Valgrind mailing lists
# - Stack Overflow discussions
#
# SAFETY:
# - These suppressions are specific to condition_variable_any operations
# - They only match when the stack includes both:
#   1. std::condition_variable_any::notify_one() or wait_for()
#   2. RelationalDBConnectionPool::close() or maintenanceTask()
# - Real races in cpp_dbc code would NOT have this specific stack pattern

{
   condition_variable_any_notify_lock_false_positive
   Helgrind:Misc
   ...
   fun:*condition_variable_any*notify_one*
   fun:*RelationalDBConnectionPool*close*
   ...
}

{
   condition_variable_any_notify_unlock_false_positive
   Helgrind:UnlockForeign
   ...
   fun:*condition_variable_any*notify_one*
   fun:*RelationalDBConnectionPool*close*
   ...
}

{
   condition_variable_any_wait_lock_false_positive
   Helgrind:Misc
   ...
   fun:*condition_variable_any*wait*
   fun:*RelationalDBConnectionPool*maintenanceTask*
   ...
}

{
   condition_variable_any_wait_unlock_false_positive
   Helgrind:UnlockForeign
   ...
   fun:*condition_variable_any*wait*
   fun:*RelationalDBConnectionPool*maintenanceTask*
   ...
}

# ============================================
# HighPerfLogger Lock-Free Ring Buffer
# ============================================
#
# Helgrind reports false positives for HighPerfLogger because it cannot track
# the synchronization provided by the atomic 'ready' flag.
#
# BACKGROUND:
# HighPerfLogger uses a lock-free ring buffer with the following protocol:
#   1. Producer thread:
#      - entry.ready = false  (atomic release)
#      - snprintf(entry.message, ...)  (non-atomic write to char[])
#      - entry.ready = true   (atomic release)
#   2. Consumer thread (disk writer):
#      - if (entry.ready == true) { (atomic acquire)
#          fwrite(entry.message, ...)  (non-atomic read from char[])
#          entry.ready = false  (atomic release)
#        }
#
# The atomic 'ready' flag provides happens-before relationship between:
# - Producer's write to message[] → Producer's store(ready=true)
# - Consumer's load(ready==true) → Consumer's read from message[]
#
# Helgrind sees the non-atomic access to message[] but cannot correlate it
# with the atomic ready flag, resulting in false positive race reports.
#
# This is a KNOWN limitation of Helgrind with lock-free data structures using
# atomic flags to protect non-atomic data.
#
# SAFETY:
# - These suppressions are SPECIFIC to HighPerfLogger code paths
# - They require BOTH producer (log()) and consumer (writerThreadFunc()) functions
# - Real races in cpp_dbc code would NOT have HighPerfLogger in the stack
#
# Stack patterns suppressed:
# 1. Producer writes to message[] via snprintf/vsnprintf
# 2. Consumer reads from message[] via ofstream::write/memmove
#

{
   high_perf_logger_producer_snprintf_write
   Helgrind:Race
   ...
   fun:*snprintf*
   fun:*HighPerfLogger*log*
   ...
}

{
   high_perf_logger_producer_vsnprintf_write
   Helgrind:Race
   ...
   fun:*vsnprintf*
   fun:*HighPerfLogger*log*
   ...
}

{
   high_perf_logger_producer_mempcpy_write
   Helgrind:Race
   fun:mempcpy
   ...
   fun:*vsnprintf*
   fun:*HighPerfLogger*log*
   ...
}

{
   high_perf_logger_producer_memcpy_write
   Helgrind:Race
   fun:memcpy*
   ...
   fun:*vsnprintf*
   fun:*HighPerfLogger*log*
   ...
}

{
   high_perf_logger_consumer_ofstream_read
   Helgrind:Race
   ...
   fun:*ostream*write*
   fun:*HighPerfLogger*writerThreadFunc*
   ...
}

{
   high_perf_logger_consumer_memmove_read
   Helgrind:Race
   fun:memmove
   ...
   fun:*ostream*write*
   fun:*HighPerfLogger*writerThreadFunc*
   ...
}

{
   high_perf_logger_consumer_memcpy_read
   Helgrind:Race
   fun:memcpy*
   ...
   fun:*ostream*write*
   fun:*HighPerfLogger*writerThreadFunc*
   ...
}

{
   high_perf_logger_consumer_streambuf_read
   Helgrind:Race
   ...
   fun:*streambuf*xsputn*
   fun:*ostream*write*
   fun:*HighPerfLogger*writerThreadFunc*
   ...
}
